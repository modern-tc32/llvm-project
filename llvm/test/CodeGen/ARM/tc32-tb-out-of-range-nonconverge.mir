# RUN: llc -mtriple=tc32-unknown-none-elf -run-pass=arm-cp-islands %s -o - | FileCheck %s

# CHECK: bb.0:
# CHECK: tB %bb.2, 14
# CHECK: bb.1:
# CHECK: tB %bb.3, 14
# CHECK: bb.2:
# CHECK: tB %bb.4, 14

--- |
  define void @tb_out_of_range_nonconverge() { ret void }
...
---
name:            tb_out_of_range_nonconverge
alignment:       2
tracksRegLiveness: false
body:             |
  bb.0:
    tB %bb.2, 14, $noreg

  bb.1:
    dead $r0 = SPACE 2050, undef $r0

  bb.2:
    tPOP_RET 14, $noreg, def $pc
...
