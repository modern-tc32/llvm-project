# RUN: llc -mtriple=tc32-unknown-none-elf -run-pass=arm-cp-islands %s -o - | FileCheck %s

# CHECK-LABEL: name: tb_backward_in_range_boundary
# CHECK: bb.0:
# CHECK: tPOP_RET 14 {{.*}}, $noreg, def $pc
# CHECK: bb.2:
# CHECK: tB %bb.0, 14

--- |
  define void @tb_backward_in_range_boundary() { ret void }
...
---
name:            tb_backward_in_range_boundary
alignment:       2
tracksRegLiveness: false
body:             |
  bb.0:
    tPOP_RET 14, $noreg, def $pc

  bb.1:
    dead $r0 = SPACE 2040, undef $r0

  bb.2:
    tB %bb.0, 14, $noreg
...
