# RUN: llc -mtriple=tc32-unknown-none-elf -run-pass=arm-cp-islands %s -o - | FileCheck %s

# CHECK-LABEL: bb.0:
# CHECK: tBL 14 {{.*}}, %bb.2, implicit-def dead $lr, implicit $sp
# CHECK: bb.2:
# CHECK: tB %bb.[[HOP1:[0-9]+]], 14 {{.*}}
# CHECK: bb.[[HOP1]]:
# CHECK: tB %bb.[[HOP2:[0-9]+]], 14 {{.*}}
# CHECK: bb.[[HOP2]]:
# CHECK: tB %bb.[[HOP3:[0-9]+]], 14 {{.*}}

--- |
  define void @f() { ret void }
...
---
name:            f
alignment:       2
tracksRegLiveness: true
body:             |
  bb.0:
    tBL 14, $noreg, %bb.2, implicit-def dead $lr, implicit $sp
    tPOP_RET 14, $noreg, def $pc

  bb.1:
    dead $r0 = SPACE 5000000, undef $r0

  bb.2:
    tPOP_RET 14, $noreg, def $pc
...
