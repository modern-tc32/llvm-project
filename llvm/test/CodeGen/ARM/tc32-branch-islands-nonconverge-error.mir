# RUN: not --crash llc -mtriple=tc32-unknown-none-elf -run-pass=arm-cp-islands %s -o - 2>&1 | FileCheck %s

# CHECK: LLVM ERROR: TC32 branch island relaxation failed to converge
# CHECK: br_iters={{[0-9]+}}
# CHECK: imm_branches={{[0-9]+}}
# CHECK: cp_users={{[0-9]+}}
# CHECK: water={{[0-9]+}}
# CHECK: split_attempts={{[0-9]+}}
# CHECK: split_success={{[0-9]+}}
# CHECK: forced_source_anchors={{[0-9]+}}
# CHECK: cond_long_fallbacks={{[0-9]+}}
# CHECK: call_long_fallbacks={{[0-9]+}}
# CHECK: first_offender_src={{[0-9a-f]+}}
# CHECK: first_offender_dst={{[0-9a-f]+}}
# CHECK: first_offender_maxdisp={{[0-9]+}}
# CHECK: first_offender_opc={{[0-9]+}}
# CHECK: first_offender_name={{[A-Za-z0-9_]+}}

--- |
  define void @f() { ret void }
...
---
name:            f
tracksRegLiveness: true
body:             |
  bb.0:
    tB %bb.3, 14, $noreg

  bb.1:
    tB %bb.3, 14, $noreg

  bb.2:
    dead $r0 = SPACE 3000, undef $r0

  bb.3:
    tPOP_RET 14, $noreg, def $pc
...
