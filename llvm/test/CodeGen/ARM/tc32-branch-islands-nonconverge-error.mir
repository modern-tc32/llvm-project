# RUN: llc -mtriple=tc32-unknown-none-elf -run-pass=arm-cp-islands %s -o - | FileCheck %s

# CHECK: bb.0:
# CHECK: tB %bb.3, 14
# CHECK: bb.1:
# CHECK: tB %bb.4, 14
# CHECK: bb.2:
# CHECK: tB %bb.5, 14

--- |
  define void @f() { ret void }
...
---
name:            f
tracksRegLiveness: true
body:             |
  bb.0:
    tB %bb.3, 14, $noreg

  bb.1:
    tB %bb.3, 14, $noreg

  bb.2:
    dead $r0 = SPACE 3000, undef $r0

  bb.3:
    tPOP_RET 14, $noreg, def $pc
...
