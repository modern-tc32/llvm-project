# RUN: llc -mtriple=tc32-unknown-none-elf -run-pass=arm-cp-islands %s -o - | FileCheck %s

# CHECK-LABEL: name: tb_in_range_boundary
# CHECK: bb.0:
# CHECK: tB %bb.2, 14

--- |
  define void @tb_in_range_boundary() { ret void }
...
---
name:            tb_in_range_boundary
alignment:       2
tracksRegLiveness: false
body:             |
  bb.0:
    tB %bb.2, 14, $noreg

  bb.1:
    dead $r0 = SPACE 2042, undef $r0

  bb.2:
    tPOP_RET 14, $noreg, def $pc
...
