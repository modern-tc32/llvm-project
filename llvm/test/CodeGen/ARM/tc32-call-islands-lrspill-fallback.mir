# RUN: llc -mtriple=tc32-unknown-none-elf -run-pass=arm-cp-islands %s -o - | FileCheck %s

--- |
  define void @f() { ret void }
...
---
name:            f
tracksRegLiveness: true
machineFunctionInfo:
  isLRSpilled:     true
body:             |
  bb.0:
    tBL 14, $noreg, %bb.2, csr_aapcs, implicit-def dead $lr, implicit $sp, implicit-def $sp
    tPOP_RET 14, $noreg, def $pc

  bb.1:
    dead $r0 = SPACE 5000000, undef $r0

  bb.2:
    tPOP_RET 14, $noreg, def $pc

# CHECK: bb.0:
# CHECK: tBfar 14, $noreg, %bb.2
