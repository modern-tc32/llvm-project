# RUN: llc -mtriple=tc32-unknown-none-elf -run-pass=arm-cp-islands %s -o - | FileCheck %s

# CHECK-LABEL: name: tc32_b_very_far_fallback
# CHECK: bb.0:
# CHECK-NOT: tB %bb.2
# CHECK: tTC32B32 %bb.2

--- |
  define void @tc32_b_very_far_fallback() { ret void }
...
---
name:            tc32_b_very_far_fallback
alignment:       2
tracksRegLiveness: false
body:             |
  bb.0:
    tB %bb.2, 14, $noreg

  bb.1:
    dead $r0 = SPACE 3000, undef $r0

  bb.2:
    tPOP_RET 14, $noreg, def $pc
...
