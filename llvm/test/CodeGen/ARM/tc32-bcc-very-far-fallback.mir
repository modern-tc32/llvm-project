# RUN: llc -mtriple=tc32-unknown-none-elf -run-pass=arm-cp-islands %s -o - | FileCheck %s

# CHECK-LABEL: bb.0:
# CHECK-NOT: tBfar
# CHECK: tBcc %bb.1, 1
# CHECK: tB %bb.[[HOP1:[0-9]+]]
# CHECK: bb.[[HOP1]]:
# CHECK: tB %bb.[[HOP2:[0-9]+]]
# CHECK: bb.[[HOP2]]:
# CHECK: tB %bb.[[FINAL:[0-9]+]]
# CHECK: bb.[[FINAL]]:
# CHECK: tPOP_RET

--- |
  define void @f() { ret void }
...
---
name:            f
alignment:       2
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $cpsr
    tBcc %bb.2, 0, killed $cpsr
    tPOP_RET 14, $noreg, def $pc

  bb.1:
    dead $r0 = SPACE 5000, undef $r0

  bb.2:
    tPOP_RET 14, $noreg, def $pc
...
